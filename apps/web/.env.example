# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n webhook for impulse intervention (server-side only, optional fallback)
N8N_INTERVENE_WEBHOOK=https://n8n.example.com/webhook/intervene

# DeepSeek (LLM principal del Aliado). Si no esta configurado, las rutas
# de chat/intervene degradan a fallback estatico sin lanzar error.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Observability
SENTRY_DSN=
POSTHOG_KEY=
