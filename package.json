{
  "name": "antiport-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/ai",
    "packages/db"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:ai": "npm --workspace packages/ai run typecheck",
    "typecheck:db": "npm --workspace packages/db run typecheck"
  }
}
